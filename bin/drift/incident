#!/usr/bin/env python3
"""OpenClaw incident ledger CLI — emit, list, show.

Phase 1: detector-side spine. Phase 2 will add propose/apply/archive/learn.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

ROOT = Path(os.environ.get("OPENCLAW_INCIDENTS_DIR", str(Path.home() / ".openclaw" / "incidents")))
STATE_FILE = ROOT / "state.json"

FRONTMATTER_RE = re.compile(r"^---\n(.*?)\n---\n(.*)$", re.DOTALL)


def now_utc() -> datetime:
    return datetime.now(timezone.utc)


def iso(dt: datetime) -> str:
    return dt.strftime("%Y-%m-%dT%H:%M:%SZ")


def day_dir(dt: datetime) -> Path:
    return ROOT / dt.strftime("%Y-%m-%d")


def slug(s: str, maxlen: int = 40) -> str:
    s = re.sub(r"[^a-zA-Z0-9]+", "-", s).strip("-").lower()
    return s[:maxlen] or "untitled"


def dump_yaml(d: dict[str, Any]) -> str:
    """Serialize top-level keys as YAML lines. Nested dicts/lists are inlined as JSON for round-trip safety."""
    lines = []
    for k, v in d.items():
        if v is None:
            lines.append(f"{k}: null")
        elif isinstance(v, bool):
            lines.append(f"{k}: {'true' if v else 'false'}")
        elif isinstance(v, (int, float)):
            lines.append(f"{k}: {v}")
        elif isinstance(v, str):
            if v == "" or any(c in v for c in ":#\n\"'") or v.strip() != v:
                lines.append(f"{k}: {json.dumps(v)}")
            else:
                lines.append(f"{k}: {v}")
        elif isinstance(v, (dict, list)):
            lines.append(f"{k}: {json.dumps(v, ensure_ascii=False)}")
        else:
            lines.append(f"{k}: {json.dumps(str(v))}")
    return "\n".join(lines)


def parse_frontmatter(text: str) -> tuple[dict[str, Any], str]:
    m = FRONTMATTER_RE.match(text)
    if not m:
        raise ValueError("missing frontmatter")
    fm_text, body = m.group(1), m.group(2)
    # We dump our own YAML; for parsing we use a permissive line-based reader.
    # Falls back to JSON parsing for nested dicts/lists serialized as JSON.
    fm: dict[str, Any] = {}
    stack: list[tuple[int, dict | list]] = [(0, fm)]
    for raw_line in fm_text.split("\n"):
        if not raw_line.strip():
            continue
        indent = len(raw_line) - len(raw_line.lstrip(" "))
        line = raw_line.strip()
        while stack and stack[-1][0] >= indent and len(stack) > 1:
            stack.pop()
        container = stack[-1][1]
        if line.startswith("- "):
            val = _scalar(line[2:].strip())
            assert isinstance(container, list)
            container.append(val)
            continue
        if ":" not in line:
            continue
        k, _, v = line.partition(":")
        k = k.strip()
        v = v.strip()
        if v == "":
            new_container: dict | list = {}
            container[k] = new_container  # type: ignore[index]
            stack.append((indent + 2, new_container))
        else:
            container[k] = _scalar(v)  # type: ignore[index]
    return fm, body


def _scalar(v: str) -> Any:
    if v == "null" or v == "~":
        return None
    if v == "true":
        return True
    if v == "false":
        return False
    if v.startswith('"') and v.endswith('"'):
        try:
            return json.loads(v)
        except json.JSONDecodeError:
            return v[1:-1]
    if v.startswith("{") or v.startswith("["):
        try:
            return json.loads(v)
        except json.JSONDecodeError:
            return v
    try:
        return int(v)
    except ValueError:
        pass
    try:
        return float(v)
    except ValueError:
        pass
    return v


@dataclass
class Incident:
    id: str
    path: Path
    fm: dict[str, Any]
    body: str

    @classmethod
    def load(cls, path: Path) -> "Incident":
        fm, body = parse_frontmatter(path.read_text())
        return cls(id=fm["id"], path=path, fm=fm, body=body)


def all_incidents() -> list[Incident]:
    out: list[Incident] = []
    if not ROOT.exists():
        return out
    for day in sorted(ROOT.iterdir()):
        if not day.is_dir() or not re.match(r"\d{4}-\d{2}-\d{2}", day.name):
            continue
        for f in sorted(day.glob("*.md")):
            try:
                out.append(Incident.load(f))
            except Exception as e:
                print(f"WARN: failed to load {f}: {e}", file=sys.stderr)
    return out


def find_by_key(key: str) -> Incident | None:
    target_id = key
    for inc in all_incidents():
        if inc.fm.get("id") == target_id or inc.fm.get("dedup_key") == key:
            return inc
    return None


# ---------- commands ----------

def cmd_emit(args: argparse.Namespace) -> int:
    detected = now_utc()
    dedup_key = args.key
    if not dedup_key:
        # Default: hash of source + title + agent + day
        h = hashlib.sha1()
        for part in [args.source, args.title or "", args.agent or "", detected.strftime("%Y-%m-%d")]:
            h.update(part.encode())
        dedup_key = h.hexdigest()[:12]

    inc_id = f"{args.source}-{dedup_key}-{detected.strftime('%Y%m%dT%H%M%SZ')}"

    # Dedup check
    existing = find_by_key(dedup_key)
    recurrence_of = None
    if existing is not None:
        if existing.fm.get("status") in ("open", "proposed"):
            print(f"DEDUP: existing {existing.id} is {existing.fm.get('status')}; skipping", file=sys.stderr)
            print(existing.id)
            return 0
        recurrence_of = existing.id

    raw_context = ""
    if args.raw_file:
        raw_context = Path(args.raw_file).read_text()
    elif not sys.stdin.isatty():
        raw_context = sys.stdin.read()

    fields: dict[str, Any] = {}
    if args.fields_json:
        fields = json.loads(args.fields_json)

    fm: dict[str, Any] = {
        "id": inc_id,
        "dedup_key": dedup_key,
        "source": args.source,
        "type": args.type or "unclassified",
        "detected_at": iso(detected),
        "status": "open",
        "severity": args.severity,
        "title": args.title or "(no title)",
        "agent": args.agent,
        "run_id": args.run_id,
        "related": json.loads(args.related_json) if args.related_json else {},
        "fields": fields,
        "proposed_fix": None,
        "confidence": None,
        "blast_radius": None,
        "applied_at": None,
        "applied_by": None,
        "recurrence_of": recurrence_of,
    }

    body_parts = [f"# {fm['title']}", "", "## Raw context", "", "```"]
    body_parts.append(raw_context.rstrip() if raw_context else "(none captured)")
    body_parts += ["```", "", "## Analysis", "", "_pending_", "", "## Decision", "", "_pending_", ""]
    body = "\n".join(body_parts)

    out_dir = day_dir(detected)
    out_dir.mkdir(parents=True, exist_ok=True)
    out_path = out_dir / f"{slug(args.source)}-{slug(args.title or 'untitled', 30)}-{detected.strftime('%H%M%S')}.md"

    out_path.write_text(f"---\n{dump_yaml(fm)}\n---\n{body}")
    print(inc_id)
    if args.print_path:
        print(out_path, file=sys.stderr)
    return 0


def cmd_list(args: argparse.Namespace) -> int:
    rows = []
    for inc in all_incidents():
        if args.status and inc.fm.get("status") != args.status:
            continue
        if args.source and inc.fm.get("source") != args.source:
            continue
        if args.type and inc.fm.get("type") != args.type:
            continue
        rows.append(inc)

    if args.json:
        print(json.dumps([{"id": r.fm["id"], **{k: r.fm.get(k) for k in ("source", "type", "status", "severity", "detected_at", "title", "agent")}} for r in rows], indent=2))
        return 0

    if not rows:
        print("(no incidents match)")
        return 0
    for r in rows:
        print(f"{r.fm.get('detected_at', '?')[:19]}  {r.fm.get('status', '?'):10}  {r.fm.get('source', '?'):14}  {r.fm.get('severity', '?'):4}  {r.fm.get('title', '?')}")
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    for inc in all_incidents():
        if inc.fm.get("id") == args.id or inc.fm.get("id", "").endswith(args.id):
            print(inc.path.read_text())
            return 0
    print(f"not found: {args.id}", file=sys.stderr)
    return 1


def cmd_state_get(args: argparse.Namespace) -> int:
    if STATE_FILE.exists():
        print(STATE_FILE.read_text())
    else:
        print("{}")
    return 0


def cmd_state_set(args: argparse.Namespace) -> int:
    state = json.loads(STATE_FILE.read_text()) if STATE_FILE.exists() else {}
    state.setdefault("sources", {}).setdefault(args.source, {})
    for kv in args.kv:
        k, _, v = kv.partition("=")
        try:
            v_parsed = json.loads(v)
        except json.JSONDecodeError:
            v_parsed = v
        state["sources"][args.source][k] = v_parsed
    STATE_FILE.write_text(json.dumps(state, indent=2) + "\n")
    return 0


def main() -> int:
    p = argparse.ArgumentParser(prog="incident")
    sub = p.add_subparsers(dest="cmd", required=True)

    pe = sub.add_parser("emit", help="emit a new incident")
    pe.add_argument("--source", required=True)
    pe.add_argument("--type", default=None)
    pe.add_argument("--severity", default="med", choices=["low", "med", "high"])
    pe.add_argument("--title", required=True)
    pe.add_argument("--agent", default=None)
    pe.add_argument("--run-id", default=None, help="cross-link to skill-runs ledger record")
    pe.add_argument("--key", default=None, help="stable dedup key")
    pe.add_argument("--related-json", default=None)
    pe.add_argument("--fields-json", default=None)
    pe.add_argument("--raw-file", default=None)
    pe.add_argument("--print-path", action="store_true")
    pe.set_defaults(func=cmd_emit)

    pl = sub.add_parser("list", help="list incidents")
    pl.add_argument("--status", default=None)
    pl.add_argument("--source", default=None)
    pl.add_argument("--type", default=None)
    pl.add_argument("--json", action="store_true")
    pl.set_defaults(func=cmd_list)

    ps = sub.add_parser("show", help="show an incident by id (or id suffix)")
    ps.add_argument("id")
    ps.set_defaults(func=cmd_show)

    pst = sub.add_parser("state", help="get/set source watcher state")
    psts = pst.add_subparsers(dest="state_cmd", required=True)
    pstg = psts.add_parser("get")
    pstg.set_defaults(func=cmd_state_get)
    psts_set = psts.add_parser("set")
    psts_set.add_argument("--source", required=True)
    psts_set.add_argument("kv", nargs="+", help="key=value pairs (value parsed as JSON if possible)")
    psts_set.set_defaults(func=cmd_state_set)

    args = p.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
