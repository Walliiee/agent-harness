#!/usr/bin/env python3
"""Drift incident undo.

Reverts an `applied` incident by reading apply_log.result.pre_state and
re-applying the inverse via the same handler. Refuses if:
  - status != applied
  - applied_by == out-of-band-detected (we didn't change anything)
  - current state has drifted (someone changed it since our apply)
  - already reverted

Updates status to `reverted` and posts a Drift ack.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(os.environ.get("OPENCLAW_INCIDENTS_DIR", str(Path.home() / ".openclaw" / "incidents")))
OPENCLAW = os.environ.get("OPENCLAW_BIN", "openclaw")

# Telegram routing — read from env, EMPTY by default. When HARNESS_TG_CHAT_ID is
# unset the Drift ack becomes a no-op (see post_drift()).
#   HARNESS_TG_CHAT_ID        — target chat/group id for the ops group
#   HARNESS_TG_DRIFT_TOPIC_ID — topic (thread) id for the Drift topic
DRIFT_CHAT = os.environ.get("HARNESS_TG_CHAT_ID", "")
DRIFT_THREAD = os.environ.get("HARNESS_TG_DRIFT_TOPIC_ID", "")
DRIFT_ACCOUNT = os.environ.get("DRIFT_ACCOUNT", "main")

FRONTMATTER_RE = re.compile(r"^---\n(.*?)\n---\n(.*)$", re.DOTALL)


def now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


# ---------- shared frontmatter I/O (mirrors incident-apply) ----------

def parse_frontmatter(text: str) -> tuple[dict, str]:
    m = FRONTMATTER_RE.match(text)
    if not m:
        raise ValueError("missing frontmatter")
    fm_text, body = m.group(1), m.group(2)
    fm: dict = {}
    for raw_line in fm_text.split("\n"):
        if not raw_line.strip() or raw_line.startswith(" "):
            continue
        if ":" not in raw_line:
            continue
        k, _, v = raw_line.partition(":")
        k, v = k.strip(), v.strip()
        fm[k] = _scalar(v)
    return fm, body


def _scalar(v: str):
    if v in ("null", "~", ""):
        return None
    if v == "true":
        return True
    if v == "false":
        return False
    if v.startswith('"') and v.endswith('"'):
        try:
            return json.loads(v)
        except json.JSONDecodeError:
            return v[1:-1]
    if v.startswith("{") or v.startswith("["):
        try:
            return json.loads(v)
        except json.JSONDecodeError:
            return v
    try:
        return int(v)
    except ValueError:
        pass
    try:
        return float(v)
    except ValueError:
        pass
    return v


def dump_yaml(d: dict) -> str:
    lines = []
    for k, v in d.items():
        if v is None:
            lines.append(f"{k}: null")
        elif isinstance(v, bool):
            lines.append(f"{k}: {'true' if v else 'false'}")
        elif isinstance(v, (int, float)):
            lines.append(f"{k}: {v}")
        elif isinstance(v, str):
            if v == "" or any(c in v for c in ":#\n\"'") or v.strip() != v:
                lines.append(f"{k}: {json.dumps(v)}")
            else:
                lines.append(f"{k}: {v}")
        elif isinstance(v, (dict, list)):
            lines.append(f"{k}: {json.dumps(v, ensure_ascii=False)}")
        else:
            lines.append(f"{k}: {json.dumps(str(v))}")
    return "\n".join(lines)


def iter_incidents() -> list[Path]:
    out = []
    if not ROOT.exists():
        return out
    for day in sorted(ROOT.iterdir()):
        if not day.is_dir() or not re.match(r"\d{4}-\d{2}-\d{2}", day.name):
            continue
        out.extend(sorted(day.glob("*.md")))
    return out


def find_by_id(inc_id: str) -> Path | None:
    for f in iter_incidents():
        try:
            fm, _ = parse_frontmatter(f.read_text())
        except Exception:
            continue
        if fm.get("id") == inc_id or (fm.get("id") or "").endswith(inc_id):
            return f
    return None


def extract_apply_log(body: str) -> dict | None:
    """Find the most recent ## Apply ... ```json ... ``` block and parse it."""
    m = re.search(r"## Apply\n+```json\n(.*?)\n```", body, re.DOTALL)
    if not m:
        return None
    try:
        return json.loads(m.group(1))
    except json.JSONDecodeError:
        return None


# ---------- per-handler undo ----------

def undo_cron_edit(plan: dict, log: dict) -> dict:
    """Reverse a cron-edit by writing pre_state values back."""
    pre = (log.get("result") or {}).get("pre_state") or {}
    cron_id = pre.get("cron_id") or (plan.get("params") or {}).get("cron_id")
    pre_fields = pre.get("fields") or {}
    if not cron_id or not pre_fields:
        return {"ok": False, "reason": "no pre_state captured — cannot undo cron-edit"}

    # Drift check: verify current values match what apply left them as (= plan's changes).
    try:
        p = subprocess.run([OPENCLAW, "cron", "show", cron_id, "--json"], capture_output=True, text=True, timeout=30)
        if p.returncode != 0:
            return {"ok": False, "reason": f"cron show failed: {p.stderr.strip()}"}
        doc = json.loads(p.stdout)
    except Exception as e:
        return {"ok": False, "reason": f"cron show error: {e}"}

    intended_after = (plan.get("params") or {}).get("changes") or {}
    field_getter = {
        "model": lambda: (doc.get("payload") or {}).get("model"),
        "cron": lambda: (doc.get("schedule") or {}).get("expr"),
        "every": lambda: (doc.get("schedule") or {}).get("every"),
        "agent": lambda: doc.get("agentId"),
        "description": lambda: doc.get("description"),
    }
    drifted = {}
    for k, expected in intended_after.items():
        current = (field_getter.get(k) or (lambda: None))()
        if str(current) != str(expected):
            drifted[k] = {"current": current, "we_set_it_to": expected}
    if drifted:
        return {"ok": False, "reason": "cron has drifted since apply — refusing to undo", "drift": drifted}

    flag_map = {
        "model": "--model", "cron": "--cron", "every": "--every",
        "agent": "--agent", "description": "--description",
    }
    cmd = [OPENCLAW, "cron", "edit", cron_id]
    for k, v in pre_fields.items():
        flag = flag_map.get(k)
        if not flag:
            return {"ok": False, "reason": f"unsupported field for undo: {k}"}
        if v is None:
            return {"ok": False, "reason": f"pre_state.{k} is null — cannot revert"}
        cmd.extend([flag, str(v)])
    p = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    if p.returncode != 0:
        return {"ok": False, "reason": f"cron edit failed: {p.stderr.strip() or p.stdout.strip()}", "command": " ".join(cmd)}
    return {"ok": True, "command": " ".join(cmd), "reverted_to": pre_fields}


def undo_file_patch(plan: dict, log: dict) -> dict:
    """Reverse a file-patch by swapping new_string back to old_string."""
    params = plan.get("params") or {}
    path_str = params.get("path")
    old_string = params.get("old_string")
    new_string = params.get("new_string")
    if not path_str or old_string is None or new_string is None:
        return {"ok": False, "reason": "file-patch undo missing path/old_string/new_string"}
    p = Path(path_str)
    if not p.exists():
        return {"ok": False, "reason": f"target file no longer exists: {p}"}
    content = p.read_text()

    # Drift check: new_string must still be present (otherwise file changed since apply).
    n_new = content.count(new_string)
    if n_new == 0:
        return {"ok": False, "reason": "new_string no longer in file — drifted since apply; refusing"}
    if n_new > 1:
        return {"ok": False, "reason": f"new_string ambiguous ({n_new} occurrences) — cannot safely undo"}

    new_content = content.replace(new_string, old_string, 1)
    p.write_text(new_content)
    return {
        "ok": True,
        "path": str(p),
        "reverted_chars": f"{len(new_string)}→{len(old_string)}",
    }


def undo_file_archive(plan: dict, log: dict) -> dict:
    """Reverse a file-archive by moving the file back to its original path."""
    import shutil
    pre = (log.get("result") or {}).get("pre_state") or {}
    src = pre.get("src")
    dst = pre.get("dst")
    if not src or not dst:
        return {"ok": False, "reason": "no pre_state (src/dst) captured"}
    src_p, dst_p = Path(src), Path(dst)
    # Drift check: file should still be at dst and absent at src
    if not dst_p.exists():
        return {"ok": False, "reason": f"archived file no longer at {dst}; cannot undo"}
    if src_p.exists():
        return {"ok": False, "reason": f"original path {src} now occupied; manual review needed"}
    src_p.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(dst_p), str(src_p))
    return {"ok": True, "command": f"file-archive undone: {dst} → {src}"}


def undo_noop(plan: dict, log: dict) -> dict:
    return {"ok": True, "noop": True, "handler": plan.get("handler"), "note": "investigate/infrastructure handlers do not modify state"}


def _read_config_value(path: str):
    try:
        p = subprocess.run([OPENCLAW, "config", "get", path, "--json"], capture_output=True, text=True, timeout=15)
        if p.returncode != 0:
            return None
        out = p.stdout.strip()
        if not out:
            return None
        return json.loads(out)
    except Exception:
        return None


def _walk_path(d: dict, dot_path: str):
    """Read a nested value from a dict by dot path; return None if any segment missing."""
    cur = d
    for seg in dot_path.split("."):
        if not isinstance(cur, dict) or seg not in cur:
            return None
        cur = cur[seg]
    return cur


def _set_path(d: dict, dot_path: str, value) -> None:
    """Set a nested value in a dict, creating intermediate dicts."""
    parts = dot_path.split(".")
    cur = d
    for seg in parts[:-1]:
        if seg not in cur or not isinstance(cur[seg], dict):
            cur[seg] = {}
        cur = cur[seg]
    cur[parts[-1]] = value


def undo_routing_fix(plan: dict, log: dict) -> dict:
    """Reverse a routing-fix by writing pre-state values back via config patch."""
    pre = (log.get("result") or {}).get("pre_state") or {}
    leaves = pre.get("leaves") or []
    if not leaves:
        return {"ok": False, "reason": "no pre_state.leaves captured — cannot undo routing-fix"}

    intended_after = (plan.get("params") or {}).get("merge") or {}

    # Drift check: each leaf path should currently equal what we set it to via the merge.
    drifted = {}
    for leaf in leaves:
        path = leaf["path"]
        we_set = _walk_path(intended_after, path)
        current = _read_config_value(path)
        if current != we_set:
            drifted[path] = {"current": current, "we_set_it_to": we_set}
    if drifted:
        return {"ok": False, "reason": "config has drifted since apply — refusing to undo", "drift": drifted}

    # Build reverse merge from pre_state.
    # If the original value was None (path didn't exist), use null to delete via config patch.
    reverse: dict = {}
    for leaf in leaves:
        _set_path(reverse, leaf["path"], leaf["value"])

    # Apply reverse via openclaw config patch.
    import tempfile
    with tempfile.NamedTemporaryFile(mode="w", suffix=".json5", delete=False) as f:
        json.dump(reverse, f)
        tmp_path = f.name
    try:
        # Dry-run first.
        p = subprocess.run([OPENCLAW, "config", "patch", "--file", tmp_path, "--dry-run", "--json"],
                           capture_output=True, text=True, timeout=30)
        if p.returncode != 0:
            return {"ok": False, "reason": f"undo dry-run failed: {(p.stderr or p.stdout).strip()[:300]}"}
        p = subprocess.run([OPENCLAW, "config", "patch", "--file", tmp_path],
                           capture_output=True, text=True, timeout=30)
        if p.returncode != 0:
            return {"ok": False, "reason": f"undo config patch failed: {(p.stderr or p.stdout).strip()[:300]}"}
    finally:
        Path(tmp_path).unlink(missing_ok=True)

    return {"ok": True, "command": f"config patch (reverted {len(leaves)} leaves)", "reverse_merge": reverse}


def dispatch_undo(plan: dict, log: dict) -> dict:
    handler = plan.get("handler")
    if handler == "cron-edit":
        return undo_cron_edit(plan, log)
    if handler == "file-patch":
        return undo_file_patch(plan, log)
    if handler == "file-archive":
        return undo_file_archive(plan, log)
    if handler == "routing-fix":
        return undo_routing_fix(plan, log)
    if handler in ("investigate", "infrastructure"):
        return undo_noop(plan, log)
    return {"ok": False, "reason": f"no undo implementation for handler: {handler!r}"}


# ---------- Drift post ----------

def post_drift(text: str) -> None:
    if not DRIFT_CHAT:
        print(f"incident-undo skip (HARNESS_TG_CHAT_ID unset): {text}", file=sys.stderr)
        return
    cmd = [
        OPENCLAW, "message", "send",
        "--channel", "telegram",
        "--account", DRIFT_ACCOUNT,
        "--target", DRIFT_CHAT,
        "--thread-id", DRIFT_THREAD,
        "--message", text,
    ]
    p = subprocess.run(cmd, capture_output=True, text=True)
    if p.returncode != 0:
        print(f"WARN: post failed: {p.stderr}", file=sys.stderr)


# ---------- undo pipeline ----------

def undo_incident(path: Path, dry_run: bool, no_post: bool) -> dict:
    raw = path.read_text()
    fm, body = parse_frontmatter(raw)

    status = fm.get("status") or ""
    if status == "reverted":
        return {"skipped": True, "reason": "already reverted"}
    if status != "applied":
        return {"skipped": True, "reason": f"status={status!r}, expected applied"}

    if fm.get("applied_by") == "out-of-band-detected":
        return {"skipped": True, "reason": "applied_by=out-of-band-detected — nothing was changed by drift-apply"}

    apply_payload = extract_apply_log(body)
    if not apply_payload:
        return {"skipped": True, "reason": "no apply log found in body"}

    plan = apply_payload.get("plan") or {}
    log = apply_payload.get("log") or {}

    if dry_run:
        return {"dry_run": True, "incident": fm.get("id"), "would_undo": plan.get("handler"), "plan": plan}

    result = dispatch_undo(plan, log)

    now = now_iso()
    if result.get("ok"):
        fm["status"] = "reverted"
        fm["reverted_at"] = now
        fm["reverted_by"] = "drift-undo"
    else:
        fm["undo_failed_at"] = now

    undo_block = {
        "ran_at": now,
        "handler": plan.get("handler"),
        "result": result,
    }
    undo_md = f"## Undo\n\n```json\n{json.dumps(undo_block, indent=2)}\n```\n"
    if "## Undo" in body:
        body = re.sub(r"## Undo\n.*?(?=\n## |\Z)", lambda _m: undo_md.rstrip("\n"), body, count=1, flags=re.DOTALL)
    else:
        body = body.rstrip() + "\n\n" + undo_md

    path.write_text(f"---\n{dump_yaml(fm)}\n---\n{body}")

    if not no_post:
        short_id = (fm.get("id") or "")[-22:]
        if result.get("ok"):
            if result.get("noop"):
                text = f"↩️ Undo (no-op) — {plan.get('handler')} doesn't modify state\nid …{short_id}"
            else:
                detail = result.get("command") or result.get("path") or plan.get("handler")
                text = f"↩️ Undone {fm.get('decided_choice','?')}\n→ {detail}\nid …{short_id}"
        else:
            text = f"❌ Undo failed\n→ {result.get('reason','(unknown)')}\nid …{short_id}"
        post_drift(text)

    return {"incident": fm.get("id"), "status": fm["status"], "result": result, "undo_log": undo_block}


# ---------- CLI ----------

def main():
    p = argparse.ArgumentParser(prog="incident-undo")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--no-post", action="store_true", help="skip Drift ack post")
    p.add_argument("id")
    args = p.parse_args()
    path = find_by_id(args.id)
    if not path:
        print(f"not found: {args.id}", file=sys.stderr)
        return 1
    result = undo_incident(path, dry_run=args.dry_run, no_post=args.no_post)
    print(json.dumps(result, indent=2))
    if result.get("skipped"):
        return 0
    if result.get("dry_run"):
        return 0
    return 0 if (result.get("result") or {}).get("ok") else 1


if __name__ == "__main__":
    sys.exit(main())
