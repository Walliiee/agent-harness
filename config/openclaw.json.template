  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": [
          "ollama/kimi-k2.7-code:cloud",
          "ollama/glm-5.2:cloud",
          "ollama/minimax-m3:cloud"
        ]
      },
      "imageModel": "ollama/kimi-k2.7-code:cloud",
      "models": {
        "anthropic/claude-opus-4-8": {
          "alias": "opus",
          "params": {
            "cacheRetention": "long"
          },
          "agentRuntime": {
            "id": "claude-cli"
          }
        },
        "ollama/glm-5.2:cloud": {
          "alias": "glmpro",
          "params": {
            "thinkingDefault": "low"
          }
        },
        "ollama/kimi-k2.7-code:cloud": {
          "alias": "kimi",
          "params": {
            "cacheRetention": "long",
            "thinkingDefault": "low"
          }
        },
        "google/gemini-3.5-flash": {
          "alias": "flash",
          "params": {
            "thinkingDefault": "medium",
            "maxTokens": 16384
          }
        },
        "ollama/minimax-m3:cloud": {
          "alias": "minimax"
        },
        "codex/gpt-5.5": {
          "alias": "codex",
          "agentRuntime": {
            "id": "codex"
          }
        },
        "anthropic/claude-sonnet-4-6": {
          "agentRuntime": {
            "id": "claude-cli"
          }
        },
        "openai/gpt-5.5": {
          "alias": "gpt"
        }
      },
      "workspace": "${OPENCLAW_HOME}/workspace",
      "bootstrapMaxChars": 24000,
      "contextLimits": {
        "memoryGetMaxChars": 50000,
        "memoryGetDefaultLines": 80
      },
      "memorySearch": {
        "enabled": true,
        "experimental": {
          "sessionMemory": false
        },
        "cache": {
          "enabled": true
        },
        "query": {
          "hybrid": {
            "enabled": true,
            "mmr": {
              "enabled": true
            },
            "temporalDecay": {
              "enabled": true
            }
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "default",
        "notifyUser": true,
        "truncateAfterCompaction": true,
        "maxActiveTranscriptBytes": "20mb",
        "keepRecentTokens": 20000,
        "reserveTokens": 16384,
        "memoryFlush": {
          "enabled": true
        }
      },
      "thinkingDefault": "low",
      "heartbeat": {
        "every": "2h",
        "model": "ollama/minimax-m3:cloud",
        "target": "none",
        "to": "${HARNESS_TG_CHAT_ID}",
        "prompt": "DEFAULT REPLY IS SILENCE. Only speak if something is actually wrong.\n\nRead HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If the heartbeat_respond tool is available and nothing needs attention, call heartbeat_respond with notify=false. If that tool is not available and nothing needs attention, reply exactly HEARTBEAT_OK with no other text. Never narrate checks, never include tool results, and never send green/all-clear summaries. Never reply with prose like 'no issues' or 'all quiet' or 'nothing to report' — those are not alerts. If something is wrong or needs attention, reply only with the brief alert text.",
        "ackMaxChars": 500,
        "lightContext": true,
        "isolatedSession": true,
        "activeHours": {
          "start": "08:00",
          "end": "23:50",
          "timezone": "Europe/Copenhagen"
        }
      },
      "subagents": {
        "maxConcurrent": 4,
        "maxSpawnDepth": 1,
        "model": {
          "primary": "ollama/kimi-k2.7-code:cloud",
          "fallbacks": [
            "ollama/minimax-m3:cloud",
            "ollama/glm-5.2:cloud",
            "codex/gpt-5.5"
          ]
        },
        "runTimeoutSeconds": 900
      },
      "sandbox": {
        "mode": "off"
      },
      "maxConcurrent": 4,
      "verboseDefault": "off",
      "contextInjection": "always",
      "skills": []
    },
    "list": [
      {
        "id": "main",
        "model": {
          "primary": "openai/gpt-5.5",
          "fallbacks": [
            "ollama/kimi-k2.7-code:cloud",
            "ollama/glm-5.2:cloud",
            "ollama/minimax-m3:cloud"
