# Never commit real state, secrets, or generated content — this repo ships
# templates and scripts only. The harness creates these in the USER's setup.

# Secrets / live config
secrets.json
*.local.json
.env
.env.*
# real config; only openclaw.json.template is tracked
openclaw.json
# your real leak-gate literals; only .scrub-denylist.example is tracked
scripts/.scrub-denylist

# Live state (hippocampus / runtime)
memory/
sessions/
incidents/
logs/
skill-runs/
*.log

# Index / DB backends
*.pglite/
*.sqlite
*.sqlite3
qmd-cache/
**/xdg-cache/
pg-data/
*.sql.gz

# OS / editor
.DS_Store
*.swp
__pycache__/
*.pyc
.venv/
node_modules/
