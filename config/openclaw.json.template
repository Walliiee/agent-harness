          "memory-promote",
          "frontmatter-guard",
          "drift-ack",
          "smoke-test",
          "github",
          "tavily",
          "browser-automation",
          "dispatching-parallel-agents"
        ]
      },
      {
        "id": "dev",
        "name": "Developer",
        "workspace": "${OPENCLAW_HOME}/workspace-dev",
        "model": {
          "primary": "openai/gpt-5.5",
          "fallbacks": [
            "ollama/kimi-k2.7-code:cloud",
            "ollama/glm-5.2:cloud"
          ]
        },
        "thinkingDefault": "low",
        "verboseDefault": "off",
        "memorySearch": {
          "enabled": true
        },
        "heartbeat": {
          "every": "4h",
          "accountId": "dev",
          "prompt": "Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If the heartbeat_respond tool is available, call it with notify=false and no notificationText unless something actually needs attention. If that tool is not available, reply exactly HEARTBEAT_OK with no other text. NEVER narrate checks, NEVER include tool results, NEVER send green/all-clear summaries, NEVER call message(action=send) for progress or clean/no-op results, and NEVER reply with prose like 'no dirty repos' or 'all quiet' — those are not alerts and must be suppressed. Only emit a visible reply when there is a real blocker, error, or stale state worth flagging; in that case return only the brief alert text."
        },
        "identity": {
          "name": "Developer",
          "emoji": "🔨"
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "fs": {
            "workspaceOnly": false
          },
          "exec": {
            "security": "full",
            "ask": "off",
            "applyPatch": {
              "workspaceOnly": false
            }
          },
          "alsoAllow": [
            "sessions_list",
            "sessions_send",
            "sessions_spawn",
            "sessions_yield",
            "subagents"
          ]
        },
        "models": {
          "codex/gpt-5.5": {
            "alias": "codex"
          },
          "openai/gpt-5.5": {
            "alias": "gpt"
          }
        },
        "skills": [
          "qmd",
          "memory-retrieve",
          "gbrain-query",
          "reports",
          "wiki-write",
          "session-cleanup",
          "workspace-audit",
          "github",
          "gh-issues",
          "diffs",
          "test-driven-development",
          "smoke-test",
          "code-review",
          "decision-log",
          "ship-check"
        ],
        "subagents": {
          "model": {
            "primary": "ollama/kimi-k2.7-code:cloud",
            "fallbacks": [
              "ollama/glm-5.2:cloud"
            ]
          }
        }
      }
    ]
